# PostgreSQL connection string (Supabase / Neon / Railway / local)
DATABASE_URL="postgresql://user:password@localhost:5432/invoice_generator"

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# Public base URL used by the browser auth client
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# --- Auth methods ---
# Email/password login is OFF unless explicitly enabled.
AUTH_EMAIL_PASSWORD="false"
# Google OAuth: enabled automatically when both creds are set.
# Authorized redirect URI in Google Cloud Console:
#   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI=""   # only if overriding the default callback

# Client-side mirrors (keep in sync with the server flags above)
NEXT_PUBLIC_AUTH_EMAIL_PASSWORD="false"
NEXT_PUBLIC_AUTH_GOOGLE="false"

# S3-compatible storage for logos / signatures.
# Defaults below target the bundled MinIO dev service (docker compose).
# For AWS: drop S3_ENDPOINT/S3_FORCE_PATH_STYLE, set real region + keys.
S3_BUCKET="invoice-uploads"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_ENDPOINT="http://localhost:9100"
S3_FORCE_PATH_STYLE="true"
# Public base for returned URLs (CDN / custom domain in prod)
S3_PUBLIC_URL="http://localhost:9100/invoice-uploads"
